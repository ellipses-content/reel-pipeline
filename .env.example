# This file holds your API keys - think of it like a private keychain.
#
# HOW TO USE THIS FILE:
#   1. Rename this file from ".env.example" to ".env"
#   2. Replace the placeholder text below with your real keys
#   3. Never share this file or upload it anywhere public (like GitHub) -
#      that's why we'll add it to .gitignore next, so it never gets
#      accidentally pushed to your repository.

# Get this from: console.anthropic.com -> API Keys
ANTHROPIC_API_KEY=your-anthropic-key-here

# Get this from: pexels.com/api (free, instant signup)
PEXELS_API_KEY=your-pexels-key-here
